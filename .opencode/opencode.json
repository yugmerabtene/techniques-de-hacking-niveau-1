{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "principal",
  "compaction": {
    "auto": true,
    "tail_turns": 10
  },
  "tool_output": {
    "max_lines": 100,
    "max_bytes": 4096
  },
  "agent": {
    "principal": { "description": "Orchestrateur pentest — coordonne les sous-agents (recon, exploit, defense)" },
    "recon": { "description": "Reconnaissance et scan (nmap, sqlmap, gobuster)" },
    "exploit": { "description": "Exploitation (Metasploit, buffer overflow, WAF bypass)" },
    "defense": { "description": "Contre-mesures, hardening, forensique, reporting" }
  }
}
